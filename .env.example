# Copier vers .env et remplir
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/music_news_radar

# Scoring Claude (étape 4) — clé à créer sur console.anthropic.com
# ANTHROPIC_API_KEY=
# SCORING_MODEL=claude-haiku-4-5      # défaut ; passer à claude-sonnet-5 si besoin
# DIGEST_RELEVANCE_THRESHOLD=60
# ALERT_HOTNESS_THRESHOLD=80

# X via l'API officielle v2 (pay-per-use ~0,005 $/tweet lu, since_id natif)
# Token : developer.x.com (nécessite la facturation pay-per-use activée)
# X_BEARER_TOKEN=
# X_MAX_ITEMS=50                    # max_results par requête (borne API : 5-100)

# Alternative Apify (nécessite un plan Apify payant — non utilisée par défaut)
# APIFY_TOKEN=
# APIFY_MAX_CHARGE_USD=0.25

# --- Ajoutés aux étapes suivantes ---
# DISCORD_WEBHOOK_URL=          # étape 5 (alertes hot)
# SMTP_HOST=                    # étape 5 (digest mail)
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# DIGEST_TO=
